{
    "name": "your-username/sales-crm-lite",
    "description": "A lightweight, single-tenant CRM system for managing leads, customers, and follow-ups. Built with PHP 8, MySQL, and Tailwind CSS.",
    "type": "project",
    "license": "MIT",
    "keywords": ["crm", "php", "mvc", "mysql", "tailwind", "portfolio"],
    "authors": [
        {
            "name": "Your Name",
            "email": "your@email.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Core/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test:unit": "phpunit --testsuite=Unit --testdox",
        "test:integration": "phpunit --testsuite=Integration --testdox"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
