# =============================================================================
# Sales CRM Lite — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Sales CRM Lite"
APP_ENV=development
# APP_ENV options: development | production
APP_URL=http://localhost:8000
APP_DEBUG=true
# APP_DEBUG: true shows stack traces; false shows generic error page

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sales_crm
DB_USER=root
DB_PASS=

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
SESSION_LIFETIME=7200
# Session lifetime in seconds (7200 = 2 hours)
SESSION_NAME=sales_crm_session

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
APP_TIMEZONE=UTC
