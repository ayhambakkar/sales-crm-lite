# =============================================================================
# Sales CRM Lite — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# PHP Dependencies
# -----------------------------------------------------------------------------
/vendor/

# -----------------------------------------------------------------------------
# Node / Tailwind CSS Build
# -----------------------------------------------------------------------------
/node_modules/
/public/assets/css/app.css

# -----------------------------------------------------------------------------
# Runtime Storage
# -----------------------------------------------------------------------------
/storage/logs/*.log
/storage/uploads/*
!/storage/logs/.gitkeep
!/storage/uploads/.gitkeep

# -----------------------------------------------------------------------------
# Test Artifacts
# -----------------------------------------------------------------------------
/.phpunit.result.cache
/coverage/
/build/

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.buildpath
.settings/
nbproject/

# -----------------------------------------------------------------------------
# Composer
# -----------------------------------------------------------------------------
composer.phar

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.log
*.cache
*.tmp
